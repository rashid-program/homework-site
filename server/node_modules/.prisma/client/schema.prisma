generator client {
  provider = "prisma-client-js"
}

// SQLite для разработки. Для PostgreSQL: поменять provider на "postgresql"
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Тип задания (1–25) ───────────────────────────────────────────────────────
model TaskType {
  id          Int     @id // номер задания: 1–25
  name        String // "Задание 1"
  topic       String // "Вычисления"
  part        Int // 1 = первая часть, 2 = вторая часть
  description String? // подробное описание типа (опционально)

  tasks Task[]
}

// ─── Задание ──────────────────────────────────────────────────────────────────
model Task {
  id        String   @id @default(uuid())
  typeId    Int
  type      TaskType @relation(fields: [typeId], references: [id])
  prototype Int // порядковый номер прототипа внутри типа

  text   String? // условие задачи (LaTeX-разметка: $\frac{1}{2}$)
  answer String? // ответ (для автопроверки)
  images String  @default("[]") // JSON-строка: ["uploads/img1.jpg"]

  difficulty Int     @default(1) // 1 = базовый, 2 = средний, 3 = сложный
  source     String? // "ФИПИ 2024", "СдамГИА" и т.д.
  sourceUrl  String? // оригинальная ссылка

  createdAt DateTime @default(now())
  createdBy String? // null = парсер, иначе userId (будущее)

  @@index([typeId])
}
